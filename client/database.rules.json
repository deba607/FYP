{
  "rules": {
    "user_activities": {
      ".read": "true",
      ".write": "true",
      ".indexOn": ["timestamp"]
    },
    "bookings": {
      ".read": "true",
      ".write": "true",
      ".indexOn": ["createdAt", "email"]
    },
    "bookingsByUser": {
      "$userId": {
        ".read": "true",
        ".write": "true"
      }
    },
    "controllers": {
      ".read": "true",
      ".write": "true",
      ".indexOn": ["createdAt", "museumId"]
    },
    "scan_logs": {
      ".read": "true",
      ".write": "true",
      ".indexOn": ["ticketId", "scannedAt", "deviceId", "museumId"]
    },
    "crowdInsights": {
      ".read": true,
      ".write": false
    },
    "crowdHistory": {
      ".read": false,
      ".write": false
    }
  }
}
