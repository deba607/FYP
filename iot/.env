# Raspberry Pi device identity
IOT_DEVICE_ID=bharat-rpi-001

# Transport: http or mqtt
IOT_TRANSPORT=http

# Backend API settings
IOT_BACKEND_BASE_URL=http://localhost:3000
IOT_VERIFY_ENDPOINT=/api/bookings/validate-ticket
IOT_API_AUTH_TOKEN=
IOT_TLS_VERIFY=true

# MQTT settings (used when IOT_TRANSPORT=mqtt)
IOT_MQTT_BROKER_HOST=localhost
IOT_MQTT_BROKER_PORT=1883
IOT_MQTT_USERNAME=
IOT_MQTT_PASSWORD=

# Scanner settings
IOT_CAMERA_INDEX=0
IOT_SCAN_INTERVAL_SECONDS=0.25

# Gate settings
IOT_GATE_OPEN_SECONDS=3
IOT_SERVO_PIN=18
IOT_INVALID_LED_PIN=24
# auto | gpiozero | rpi_gpio | mock
IOT_HARDWARE_MODE=auto

# Logging
IOT_LOG_LEVEL=INFO
